{
  "name": "terminuz",
  "version": "2.0.3",
  "description": "Terminuz - The Open Source AI Coding Agent",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/N1ghthill/terminuz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/terminuz.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/terminuz/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "code-agent",
    "developer-tools",
    "terminal",
    "tui",
    "typescript",
    "llm",
    "claude",
    "anthropic",
    "openai",
    "gpt",
    "deepseek",
    "ollama",
    "openrouter",
    "mcp",
    "model-context-protocol",
    "multi-provider",
    "cli"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "bin": {
    "terminuz": "dist/index.js"
  },
  "exports": {
    "./cli": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "TSX_TSCONFIG_PATH=tsconfig.dev.json node --watch --import tsx src/index.ts --cwd \"$INIT_CWD\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "pnpm --filter @terminuz/cli build && pnpm build && vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "effect": "^3.12.7",
    "ink": "^7.0.3",
    "react": "^19.2.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@terminuz/cli": "workspace:*",
    "@types/node": "^22.20.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
