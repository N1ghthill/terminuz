{
  "name": "deepcode-ai",
  "version": "1.3.0",
  "description": "Compatibility package for users migrating from DeepCode to Terminuz",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/N1ghthill/terminuz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/terminuz.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/terminuz/issues"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "bin": {
    "deepcode": "dist/index.js",
    "deepcode-ai": "dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "terminuz": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
