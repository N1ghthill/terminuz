{
  "name": "deepcode-ai",
  "version": "1.1.22",
  "description": "Terminal AI coding agent for local software development",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/N1ghthill/deepcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/deepcode.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/deepcode/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "developer-tools",
    "terminal",
    "tui",
    "typescript"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "bin": {
    "deepcode": "dist/index.js",
    "deepcode-ai": "dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "TSX_TSCONFIG_PATH=tsconfig.dev.json node --watch --import tsx src/index.ts --cwd \"$INIT_CWD\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "pnpm build && vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "effect": "^3.12.7",
    "ink": "^7.0.3",
    "react": "^19.2.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@deepcode/cli": "workspace:*",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
