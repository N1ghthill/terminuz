{
  "name": "@deepcode/cli",
  "version": "1.0.0",
  "private": true,
  "description": "Terminal UI and command surface for DeepCode",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/N1ghthill/deepcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/deepcode.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/deepcode/issues"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@deepcode/core": "workspace:*",
    "@deepcode/shared": "workspace:*",
    "@types/diff": "^8.0.0",
    "ansi-regex": "^6.2.2",
    "chalk": "^5.4.1",
    "cli-spinners": "^2.9.2",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "fzf": "^0.5.2",
    "highlight.js": "^11.11.1",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "lowlight": "^3.3.0",
    "react": "^19.2.0",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^10.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.4",
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
