{
  "name": "@terminuz/core",
  "version": "1.1.31",
  "private": true,
  "description": "Core engine for Terminuz",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/N1ghthill/terminuz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/terminuz.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/terminuz/issues"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run --passWithNoTests",
    "test:anthropic:live": "vitest run test/anthropic-provider.live.test.ts"
  },
  "dependencies": {
    "@terminuz/shared": "workspace:*",
    "effect": "^3.12.7",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
