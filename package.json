{
  "name": "terminuz-monorepo",
  "version": "1.0.1",
  "private": true,
  "description": "Terminuz - The Open Source AI Coding Agent",
  "homepage": "https://github.com/N1ghthill/terminuz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/terminuz.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/terminuz/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter terminuz dev",
    "lint": "turbo run lint",
    "secrets:scan": "bash scripts/check-secrets.sh",
    "test": "pnpm --filter @terminuz/shared test && pnpm --filter @terminuz/core test && pnpm --filter @terminuz/cli test && pnpm --filter terminuz test && pnpm --filter deepcode-ai test",
    "test:turbo": "turbo run test",
    "typecheck": "turbo run typecheck",
    "validate": "pnpm secrets:scan && pnpm audit && pnpm audit --prod && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "promote-stable": "node scripts/promote-stable.mjs",
    "promote-stable:legacy": "node scripts/promote-stable.mjs deepcode-ai",
    "release:ga": "node scripts/release.mjs terminuz release",
    "release:patch": "node scripts/release.mjs terminuz patch",
    "release:minor": "node scripts/release.mjs terminuz minor",
    "release:major": "node scripts/release.mjs terminuz major",
    "release:legacy:ga": "node scripts/release.mjs deepcode-ai release",
    "release:legacy:patch": "node scripts/release.mjs deepcode-ai patch",
    "release:legacy:minor": "node scripts/release.mjs deepcode-ai minor",
    "release:legacy:major": "node scripts/release.mjs deepcode-ai major"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "js-yaml@>=4.0.0 <=4.1.1": "4.2.0",
      "vite@>=7.0.0 <=7.3.4": "7.3.5",
      "vitest@>=3.0.0 <3.2.6": "3.2.6",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.9.14",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
