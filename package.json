{
  "name": "deepcode-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "DeepCode AI coding agent monorepo",
  "homepage": "https://github.com/N1ghthill/deepcode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N1ghthill/deepcode.git"
  },
  "bugs": {
    "url": "https://github.com/N1ghthill/deepcode/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter deepcode-ai dev",
    "lint": "turbo run lint",
    "secrets:scan": "bash scripts/check-secrets.sh",
    "test": "pnpm --filter @deepcode/shared test && pnpm --filter @deepcode/core test && pnpm --filter @deepcode/cli test && pnpm --filter deepcode-ai test",
    "test:turbo": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
